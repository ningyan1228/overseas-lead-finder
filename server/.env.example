# Server
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
ALLOWED_ORIGINS=https://YOUR_GITHUB_USERNAME.github.io,http://127.0.0.1:8080
ADMIN_PASSWORD=replace-with-a-long-unique-password
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=8h

# Search. Do not expose this key to the frontend.
SEARCH_PROVIDER=serpapi
SERPAPI_API_KEY=

# Notion: share the five databases with the same integration.
NOTION_TOKEN=secret_
NOTION_PARENT_PAGE_ID=
NOTION_PRODUCTS_DATABASE_ID=
NOTION_SEARCH_TASKS_DATABASE_ID=
NOTION_COMPANIES_DATABASE_ID=
NOTION_CONTACTS_DATABASE_ID=
NOTION_SOURCES_DATABASE_ID=

# Worker safety limits
WORKER_POLL_MS=15000
SEARCH_REQUEST_DELAY_MS=1500
MAX_COMPANIES_PER_TASK=100

